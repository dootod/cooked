{
  "name": "@cooked/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:admin": "tsx --env-file=.env src/scripts/seed-admin.ts",
    "seed": "tsx --env-file=.env src/scripts/seed.ts"
  },
  "dependencies": {
    "@cooked/db": "workspace:*",
    "@hono/node-server": "^2.0.2",
    "@upstash/redis": "^1.38.0",
    "better-auth": "^1.6.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
